# Copy to aws-baseline.tfvars and adjust for your AWS account.

aws_region            = "eu-central-1"
aws_availability_zone = "eu-central-1c"
aws_profile           = "default"

vpc_cidr    = "10.76.0.0/16"
subnet_cidr = "10.76.1.0/24"

benchmark_machine_type = "c6i.large"

# Ubuntu 24.04 AMI in eu-central-1. Replace for other regions.
benchmark_image_id = "ami-04baa57774212d79f"

# Option A: create a new AWS key pair from a local public key.
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Option B: use an existing AWS key pair and matching private key.
# existing_key_pair_name = "my-existing-aws-keypair"
# ssh_private_key_path   = "~/.ssh/my-existing-aws-keypair.pem"

ssh_ingress_cidr = "0.0.0.0/0"
assign_public_ip = true

benchmark_root_volume_size_gib = 30
benchmark_root_volume_type     = "gp3"

# auto prepares AWS instance-store NVMe disks when the selected instance type
# provides them. Use "disabled" to skip local storage preparation.
benchmark_local_storage     = "auto"
benchmark_local_mount_point = "/mnt/local"

benchmark_block_volume_size_gib        = 100
benchmark_block_volume_type            = "gp3"
benchmark_block_volume_iops            = 3000
benchmark_block_volume_throughput_mbps = 125
