# Copy to baseline.tfvars in this directory and adjust for your AWS account.

aws_region            = "eu-central-1"
aws_profile           = "default"

vpc_cidr           = "10.74.0.0/16"
client_subnet_cidr = "10.74.1.0/24"
server_subnet_cidr = "10.74.2.0/24"

client_availability_zone = "eu-central-1c"
server_availability_zone = "eu-central-1c"

client_machine_type = "c6id.large"
server_machine_type = "c6id.large"

# Ubuntu 24.04 AMI in eu-central-1. Replace for other regions.
image_id = "ami-04baa57774212d79f"

# Option A: create a new AWS key pair from a local public key.
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Option B: use an existing AWS key pair and matching private key.
# existing_key_pair_name = "my-existing-aws-keypair"
# ssh_private_key_path   = "~/.ssh/my-existing-aws-keypair.pem"

ssh_ingress_cidr = "0.0.0.0/0"
assign_public_ip = true

root_volume_size_gib = 30
root_volume_type     = "gp3"
instance_affinity    = "none"
