# Copy to basic-infra.tfvars and adjust for your STACKIT project.

stackit_project_id = "your-project-id"
stackit_region = "eu01"
subnet_cidr = "10.65.0.0/24"
runner_private_ip_host = 10
runner_availability_zone = "eu01-1"
runner_machine_type = "c2i.2"
image_id = "your-image-id"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"
ssh_ingress_cidr = "0.0.0.0/0"
ipv4_nameservers = ["1.1.1.1", "8.8.8.8"]
root_volume_size_gib = 30
root_volume_performance_class = ""
